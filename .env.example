# Optional: OpenAI for LLM diagnosis (otherwise manual RAG-style text is returned)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# API CORS (comma-separated)
CORS_ORIGINS=*

# Streamlit dashboard → FastAPI
TRACTOR_API_URL=http://127.0.0.1:8000

# Default: sqlite:///./tractor_logs.db under backend cwd
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://tractor:tractor@localhost:5432/tractor_pm
